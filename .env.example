# Vulhub-Web Configuration
# Copy this file to .env and modify as needed

# Vulhub root directory (path to vulhub repository clone)
VULHUB_ROOT_PATH=/path/to/vulhub

# Server port
SERVER_PORT=8088

# Idle timeout in hours (0 = disabled)
IDLE_TIMEOUT_HOURS=0

# Default: remove Docker images on destroy
DEFAULT_REMOVE_IMAGE=true

# Cron expressions for scheduled tasks
SCAN_CRON="0 */6 * * *"
CLEANUP_CRON="0 2 * * *"

# JWT secret (auto-generated if empty)
SECRET_KEY=
